	sub X periodcentered.case S E by X_S_E;
	}ligaturesinclusives;
} liga;

feature ss01 {
# automatic
featureNames {
	name "Alternate punctuation";
};
sub comma by comma.ss01;
sub quotesinglbase by quotesinglbase.ss01;
sub quotedblbase by quotedblbase.ss01;
sub quotedblleft by quotedblleft.ss01;
sub quotedblright by quotedblright.ss01;
sub quoteleft by quoteleft.ss01;
sub quoteright by quoteright.ss01;
} ss01;

feature ss02 {
# automatic
featureNames {
	name "Alternate a";
};
sub a by a.ss02;
sub aacute by aacute.ss02;
sub abreve by abreve.ss02;
sub acircumflex by acircumflex.ss02;
sub adieresis by adieresis.ss02;
sub agrave by agrave.ss02;
sub amacron by amacron.ss02;
sub aogonek by aogonek.ss02;
sub aring by aring.ss02;
sub atilde by atilde.ss02;
sub ae by ae.ss02;
sub aeacute by aeacute.ss02;
} ss02;

feature ss03 {
# automatic
featureNames {
	name "Alternate g";
};
sub g by g.ss03;
sub gbreve by gbreve.ss03;
sub gcommaaccent by gcommaaccent.ss03;
sub gdotaccent by gdotaccent.ss03;
} ss03;

feature ss04 {
# automatic
featureNames {
	name "Alternate numbers";
};
sub three by three.ss04;
sub six by six.ss04;
sub nine by nine.ss04;
} ss04;

feature rlig {
	sub period period by periodcentered;
	sub periodcentered' @Uppercase by periodcentered.case;
	sub period period period by ellipsis;
	sub periodcentered period by ellipsis;
	sub periodcentered.case period by ellipsis;

