	sub O periodcentered.case I N E by O_IDIERESIS_N_E;
	sub O periodcentered.case Idieresis N E by O_IDIERESIS_N_E;
	sub O periodcentered.case T E by O_T_E;
	sub P periodcentered.case E by P_E;
